# Environment overrides for config.ini (useful in managed desktop deployments)
SHOPSYNC_DB_SERVER=localhost\\SQLEXPRESS
SHOPSYNC_DB_DATABASE=ShopSyncDB
SHOPSYNC_DB_DRIVER=ODBC Driver 17 for SQL Server
SHOPSYNC_DB_TRUSTED_CONNECTION=yes
# For SQL authentication instead:
# SHOPSYNC_DB_USERNAME=shopsync_user
# SHOPSYNC_DB_PASSWORD=replace-with-a-secret
